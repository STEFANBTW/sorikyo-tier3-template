// ============================================================
// SoriKyo Tier 3 — Prisma Schema
// ACID-compliant PostgreSQL with pgvector (1536-dim embeddings)
// ============================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

// ─── Omni Service Inventory ──────────────────────────────
// Replaces Spatial_Commerce_Inventory in Phase 1 Omni-Stack upgrades
// Stores product/service inventory with 3D model metadata

model Omni_Service_Inventory {
  id                    String   @id @default(uuid())
  sku                   String   @unique
  name                  String
  description           String?
  duration_minutes      Int      @default(60)
  price                 Float
  stock_count           Int      @default(0)
  category              String?
  draco_glb_url         String?  
  normal_map_url        String?  
  pbr_roughness_metadata Json?    
  thumbnailUrl          String?
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([category])
  @@index([isActive])
  @@map("omni_service_inventory")
}

// ─── Enterprise Booking Engine ──────────────────────────────
// ACID-compliant booking with strict unique constraints

model Enterprise_Booking {
  id               String   @id @default(uuid())
  customerName     String
  customerPhone    String
  serviceId        String
  staffId          String
  startTime        DateTime
  endTime          DateTime
  status           BookingStatus @default(PENDING)
  deposit_paid     Float         @default(0)
  paymentReference String?       @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  // CRITICAL: Prevent double-booking overlapping slots mathematically
  @@unique([staffId, startTime], name: "unique_staff_starttime")
  @@unique([staffId, endTime], name: "unique_staff_endtime")
  
  @@index([serviceId])
  @@index([staffId])
  @@index([startTime, endTime])
  @@map("enterprise_bookings")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  NO_SHOW
  COMPLETED
}

// ─── Staff Member ───────────────────────────────────────────

model Staff_Member {
  id        String   @id @default(uuid())
  name      String
  role      String
  email     String   @unique
  is_active Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("staff_members")
}

// ─── Verified Review ────────────────────────────────────────

model Verified_Review {
  id         String   @id @default(uuid())
  booking_id String   @unique 
  rating     Int      
  text       String
  createdAt  DateTime @default(now())

  @@map("verified_reviews")
}

// ─── Knowledge Embedding (pgvector) ─────────────────────────
// Stores 1536-dimensional vectors from OpenAI text-embedding-3-small

model Knowledge_Embedding {
  id        String   @id @default(uuid())
  content   String
  metadata  Json?
  source    String?
  embedding Unsupported("vector(1536)")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("knowledge_embeddings")
}

// ─── Dynamic QR Analytics ───────────────────────────────────

model Dynamic_QR_Analytics {
  id               String   @id @default(uuid())
  campaignId       String   @map("target_campaign_id")
  deviceType       String?  @map("device_type")
  userAgent        String?  @map("user_agent")
  ipAddress        String?  @map("ip_address")
  geolocationLat   Float?   @map("geolocation_lat_lng_lat")
  geolocationLng   Float?   @map("geolocation_lat_lng_lng")
  referrer         String?
  scannedAt        DateTime @default(now())

  campaign         QR_Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([scannedAt])
  @@map("dynamic_qr_analytics")
}

// ─── QR Campaign ────────────────────────────────────────────

model QR_Campaign {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  targetUrl   String   @map("target_url")
  isActive    Boolean  @default(true)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  analytics   Dynamic_QR_Analytics[]

  @@index([isActive])
  @@map("qr_campaigns")
}
