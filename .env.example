# ============================================================
# SoriKyo Tier 3 — Environment Variables
# Copy this file to .env and fill in the values.
# ============================================================

# --- Supabase PostgreSQL (Prisma) ---
# Connection pooler URL (Transaction mode) for runtime queries
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection URL for Prisma migrations (bypasses pooler)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# --- OpenAI ---
OPENAI_API_KEY="sk-..."

# --- Server ---
SERVER_PORT=3000

# --- Supabase Public (for frontend Service Worker / RLS) ---
SUPABASE_URL="https://[project-ref].supabase.co"
SUPABASE_ANON_KEY="eyJ..."

# --- Frontend Origin (CORS whitelist) ---
FRONTEND_ORIGIN="http://localhost:3000"
